#!/usr/bin/env bash
# Wrapper that runs the strudel MCP server under Node 22 with cwd set so
# config.json (next to dist/) is found correctly.
set -euo pipefail
SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
PROJECT_DIR="$( cd "$SCRIPT_DIR/.." && pwd )"
export NVM_DIR="$HOME/.nvm"
# shellcheck source=/dev/null
. "$NVM_DIR/nvm.sh"
nvm use 22 >/dev/null
cd "$PROJECT_DIR/vendor/strudel-mcp"
exec node dist/index.js "$@"
